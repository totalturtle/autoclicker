<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 오버레이(플로팅 버튼) 권한 -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <!-- 포그라운드 서비스 유지 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC"
        android:minSdkVersion="34" />

    <application
        android:name=".AutoClickerApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AutoClicker">

        <!-- 메인 화면 -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 접근성 서비스 (핵심: 자동 클릭 실행) -->
        <service
            android:name=".AutoClickAccessibilityService"
            android:exported="true"
            android:label="@string/accessibility_service_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- 플로팅 오버레이 서비스 -->
        <service
            android:name=".OverlayService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- 프로필 관리 화면 -->
        <activity
            android:name=".ProfileManagerActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <!-- 통계/로그 화면 -->
        <activity
            android:name=".StatsActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <!-- 설정 화면 -->
        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <!-- 포인트 세부 설정 (투명 다이얼로그 Activity) -->
        <activity
            android:name=".PointSettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.AutoClicker.TransparentDialog"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:excludeFromRecents="true" />

        <!-- 좌표 피커 오버레이 서비스 -->
        <service
            android:name=".CoordPickerService"
            android:exported="false" />

        <!-- 좌표 시각화 오버레이 서비스 -->
        <service
            android:name=".CoordOverlayService"
            android:exported="false" />

        <!-- 빠른 설정 타일 -->
        <service
            android:name=".AutoClickTileService"
            android:exported="true"
            android:icon="@drawable/ic_qs_autoclicker"
            android:label="@string/tile_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

    </application>
</manifest>
